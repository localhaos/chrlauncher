+BOOLEAN _app_is_singleton_path_locked (
+	_In_ PR_STRINGREF path
+)
+{
+	HANDLE hfile;
+	DWORD error_code;
+
+	if (!path || !path->buffer || !path->length)
+		return FALSE;
+
+	hfile = CreateFileW (
+		path->buffer,
+		GENERIC_READ,
+		0,
+		NULL,
+		OPEN_EXISTING,
+		FILE_ATTRIBUTE_NORMAL,
+		NULL
+	);
+
+	if (hfile == INVALID_HANDLE_VALUE)
+	{
+		error_code = GetLastError ();
+
+		return error_code == ERROR_SHARING_VIOLATION || error_code == ERROR_LOCK_VIOLATION || error_code == ERROR_ACCESS_DENIED;
+	}
+
+	NtClose (hfile);
+
+	return FALSE;
+}
+
+BOOLEAN _app_is_same_browser_instance_running (
+	_In_ PBROWSER_INFORMATION pbi
+)
+{
+	static LPCWSTR const singleton_names[] = {
+		L"SingletonLock",
+		L"SingletonCookie",
+		L"SingletonSocket",
+	};
+
+	PR_STRING singleton_path;
+
+	if (!pbi)
+		return FALSE;
+
+	if (!_app_config_getboolean (L"ChromiumSameInstanceCheck", TRUE))
+	{
+		if (!_r_obj_isstringempty (pbi->binary_path))
+			return _r_fs_isfileused (&pbi->binary_path->sr);
+
+		return FALSE;
+	}
+
+	if (_r_obj_isstringempty (pbi->user_data_dir))
+	{
+		if (!_r_obj_isstringempty (pbi->binary_path))
+			return _r_fs_isfileused (&pbi->binary_path->sr);
+
+		return FALSE;
+	}
+
+	for (ULONG_PTR i = 0; i < RTL_NUMBER_OF (singleton_names); i++)
+	{
+		singleton_path = _r_format_string (L"%s\\%s", pbi->user_data_dir->buffer, singleton_names[i]);
+
+		if (!singleton_path)
+			continue;
+
+		if (_r_fs_exists (&singleton_path->sr) && _app_is_singleton_path_locked (&singleton_path->sr))
+		{
+			_r_obj_dereference (singleton_path);
+
+			return TRUE;
+		}
+
+		_r_obj_dereference (singleton_path);
+	}
+
+	return FALSE;
+}
