{
  "manifest_version": 3,
  "key": "",
  "name": "chrlauncher CF Manual Helper",
  "version": "1.0.2",
  "description": "Detects security challenge pages and shows manual-session diagnostics without bypassing or solving challenges.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "https://*.facebook.com/*",
        "https://facebook.com/*",
        "https://*.fbcdn.net/*",
        "https://*.messenger.com/*",
        "https://messenger.com/*",
        "https://*.instagram.com/*",
        "https://instagram.com/*",
        "https://*.whatsapp.com/*",
        "https://web.whatsapp.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://music.youtube.com/*",
        "https://open.spotify.com/*",
        "https://*.soundcloud.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "CF Manual Helper",
    "default_popup": "popup.html"
  }
}
