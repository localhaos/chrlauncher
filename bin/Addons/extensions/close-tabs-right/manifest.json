{
  "manifest_version": 3,
  "key": "",
  "name": "chrlauncher Tab Tools",
  "version": "1.6.5",
  "description": "Adds tab actions, local site-test helpers, and ChatGPT download repair. DevTools helpers are kept as optional standalone addons.",
  "permissions": [
    "contextMenus",
    "downloads",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://adblock.turtlecute.org/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.oaiusercontent.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://adblock.turtlecute.org/*"
      ],
      "js": [
        "site_test_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "chatgpt_download_content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "chatgpt_download_page_hook.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Tab tools"
  }
}
