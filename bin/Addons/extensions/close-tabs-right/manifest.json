{
  "manifest_version": 3,
  "name": "chrlauncher Tab Tools",
  "version": "1.3.0",
  "description": "Adds tab actions, local site-test helpers, and safe Cloudflare manual diagnostics.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://adblock.turtlecute.org/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://adblock.turtlecute.org/*"
      ],
      "js": [
        "site_test_content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "cf_manual_helper.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Tab tools"
  }
}
